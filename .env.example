# Copy to .env and fill from Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@o000000.ingest.sentry.io/0000000
# After changing .env, restart Metro: npx expo start -c
# Phone + local Supabase: use your computer’s LAN IP (not localhost); Android emulator often uses 10.0.2.2

# Build-time Sentry source map upload config (do not prefix with EXPO_PUBLIC_)
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
SENTRY_ORG=YOUR_SENTRY_ORG_SLUG
SENTRY_PROJECT=YOUR_SENTRY_PROJECT_SLUG
# Optional; defaults to https://sentry.io/
# SENTRY_URL=https://sentry.io/

# Google sign-in: enable the provider in Supabase + Google Cloud (see docs/google-oauth-setup.md).

# After creating the project, run supabase/schema.sql in the SQL editor.
# If you already ran an older schema, apply supabase/invites_addon.sql for invites + member list.
# If join_household predates the solo-kitchen guard, run supabase/patches/join_household_solo_guard.sql.
# Disable "Confirm email" for faster local testing, or confirm via email link.
